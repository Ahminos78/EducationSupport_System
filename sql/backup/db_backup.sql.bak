INSERT INTO `tb_question` VALUES (1,1,0,'Spring Boot 中，以下哪个注解用于启动自动配置？','[\"@EnableAutoConfiguration\",\"@SpringBootApplication\",\"@Configuration\",\"@ComponentScan\"]','B',10,1,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(2,1,0,'HTTP 状态码 401 表示什么？','[\"服务器内部错误\",\"资源未找到\",\"未授权（需要身份验证）\",\"请求超时\"]','C',10,2,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(3,1,0,'以下哪个是 MyBatis Plus 的核心功能？','[\"自动建表\",\"代码生成器\",\"分布式事务\",\"服务网格\"]','B',10,3,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(4,1,0,'JWT 中 Token 通常存放在 HTTP 请求的哪个头部？','[\"Authorization\",\"Content-Type\",\"Accept\",\"Cookie\"]','A',10,4,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(5,1,1,'Spring Boot 默认内嵌的 Web 服务器是 ______。',NULL,'Tomcat',10,5,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(6,1,1,'MyBatis Plus 中，逻辑删除的全局配置属性是 ______。',NULL,'logic-delete-field',10,6,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(7,3,0,'MyBatis Plus 中，以下哪个注解用于标识主键？','[\"@TableId\",\"@TableField\",\"@TableName\",\"@Key\"]','A',20,1,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(8,3,0,'BaseMapper 接口中，用于根据 ID 查询的方法是？','[\"selectOne\",\"selectById\",\"getById\",\"findById\"]','B',20,2,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(9,3,0,'MyBatis Plus 的条件构造器类是？','[\"QueryWrapper\",\"ConditionBuilder\",\"SqlBuilder\",\"CriteriaQuery\"]','A',20,3,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(10,3,0,'以下哪个 MyBatis Plus 功能可以实现自动填充时间字段？','[\"MetaObjectHandler\",\"TimeHandler\",\"FieldFill\",\"AutoDate\"]','A',20,4,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(11,3,0,'MyBatis Plus 的分页插件是？','[\"PaginationInterceptor\",\"PageHelper\",\"MyBatisPage\",\"DataPager\"]','A',20,5,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(12,4,0,'Pandas 中，读取 CSV 文件的函数是？','[\"read_excel\",\"read_csv\",\"load_csv\",\"import_csv\"]','B',12,1,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(13,4,0,'NumPy 中，创建全零数组的函数是？','[\"ones\",\"zeros\",\"empty\",\"full\"]','B',12,2,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(14,4,0,'Pandas 中，用于删除缺失值的函数是？','[\"fillna\",\"dropna\",\"remove_na\",\"delete_na\"]','B',12,3,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(15,4,0,'以下哪个库主要用于数据可视化？','[\"Pandas\",\"NumPy\",\"Matplotlib\",\"Scipy\"]','C',12,4,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(16,4,1,'Pandas 中，按列筛选的语法是 df[______]？',NULL,'列名',12,5,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(17,4,1,'NumPy 数组的维度属性是 ______。',NULL,'shape',12,6,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(18,4,1,'Pandas 中，分组聚合的函数是 ______。',NULL,'groupby',14,7,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(19,4,1,'Matplotlib 中，显示图形的函数是 plt.______()。',NULL,'show',14,8,'2026-07-14 14:54:52','2026-07-14 14:54:52'),(20,2,0,'数据库设计中，以下哪个是逻辑设计的产物？','[\"E-R图\",\"关系模式\",\"物理存储结构\",\"索引文件\"]','B',20,1,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(21,2,0,'MySQL 中，以下哪个存储引擎支持事务？','[\"MyISAM\",\"InnoDB\",\"Memory\",\"Archive\"]','B',20,2,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(22,2,0,'以下哪个是索引的类型？','[\"B+树索引\",\"链表索引\",\"栈索引\",\"队列索引\"]','A',20,3,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(23,2,1,'数据库事务的四个特性简称 ______。',NULL,'ACID',20,4,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(24,2,1,'MyBatis Plus 中，逻辑删除的字段值 1 表示 ______。',NULL,'已删除',20,5,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(25,5,0,'Spring Boot 的默认配置文件是？','[\"application.properties\",\"spring.xml\",\"web.xml\",\"config.yml\"]','A',10,1,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(26,5,0,'以下哪个注解用于将类标记为配置类？','[\"@Component\",\"@Service\",\"@Configuration\",\"@Bean\"]','C',10,2,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(27,5,0,'Spring Boot 内嵌的 Tomcat 默认端口是？','[\"8080\",\"80\",\"8443\",\"9090\"]','A',10,3,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(28,5,0,'Actuator 的健康检查端点路径是？','[\"/health\",\"/info\",\"/metrics\",\"/status\"]','A',10,4,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(29,5,0,'以下哪个是 Spring Cloud 的服务注册中心？','[\"Nacos\",\"Redis\",\"RabbitMQ\",\"Elasticsearch\"]','A',10,5,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(30,5,1,'Spring Boot 中，读取配置文件的注解是 @______。',NULL,'Value',10,6,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(31,5,1,'Spring Boot 的自动配置核心注解是 @______。',NULL,'EnableAutoConfiguration',10,7,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(32,5,1,'将 Spring Boot 应用打包成可执行 JAR 的插件是 ______。',NULL,'spring-boot-maven-plugin',10,8,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(33,5,1,'微服务架构中，API 网关常用的功能是 ______ 和路由。',NULL,'负载均衡',10,9,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(34,5,1,'Spring Cloud 中，负载均衡的客户端是 ______。',NULL,'Ribbon',10,10,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(35,6,0,'栈的运算特点是？','[\"先进先出\",\"先进后出\",\"随机访问\",\"双端进出\"]','B',10,1,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(36,6,0,'以下哪种数据结构适合实现广度优先搜索？','[\"栈\",\"队列\",\"数组\",\"链表\"]','B',10,2,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(37,6,0,'二叉树中，度为 2 的节点数比叶子节点数少？','[\"0\",\"1\",\"2\",\"不确定\"]','B',10,3,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(38,6,0,'快速排序的平均时间复杂度是？','[\"O(n)\",\"O(nlogn)\",\"O(n²)\",\"O(logn)\"]','B',10,4,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(39,6,0,'哈希表解决冲突的方法不包括？','[\"链地址法\",\"开放地址法\",\"再哈希法\",\"冒泡法\"]','D',10,5,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(40,6,1,'线性表的顺序存储结构称为 ______。',NULL,'顺序表',10,6,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(41,6,1,'完全二叉树可以用 ______ 存储结构实现。',NULL,'顺序',10,7,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(42,6,1,'图的深度优先遍历使用的辅助数据结构是 ______。',NULL,'栈',10,8,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(43,6,1,'折半查找要求线性表必须采用 ______ 存储结构。',NULL,'顺序',10,9,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(44,6,1,'最小生成树的经典算法有 Prim 和 ______。',NULL,'Kruskal',10,10,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(45,7,0,'Vue3 中，以下哪个是组合式 API 的入口函数？','[\"setup\",\"data\",\"created\",\"mounted\"]','A',10,1,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(46,7,0,'Vue3 中，创建响应式变量的函数是？','[\"ref\",\"reactive\",\"computed\",\"watch\"]','A',10,2,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(47,7,0,'Vue Router 中，用于导航到新路径的方法是？','[\"push\",\"go\",\"link\",\"navigate\"]','A',10,3,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(48,7,0,'以下哪个是 Vue3 的状态管理库？','[\"Pinia\",\"Vuex\",\"Redux\",\"MobX\"]','A',10,4,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(49,7,0,'Vue3 中，侦听器函数是？','[\"watch\",\"watchEffect\",\"computed\",\"onMounted\"]','A',10,5,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(50,7,1,'Vue3 中，模板循环渲染的指令是 v-______。',NULL,'for',10,6,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(51,7,1,'Vue3 组件间传递数据使用 ______。',NULL,'props',10,7,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(52,7,1,'Vue3 中，获取 DOM 元素的特殊属性是 ref 和 ______。',NULL,'template ref',8,8,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(53,7,1,'Vite 的开发服务器默认端口是 ______。',NULL,'5173',8,9,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(54,7,1,'Element Plus 的表格组件是 el-______。',NULL,'table',12,10,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(55,8,0,'以下哪个是监督学习的典型任务？','[\"分类\",\"聚类\",\"降维\",\"关联规则\"]','A',12,1,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(56,8,0,'线性回归的损失函数通常使用？','[\"均方误差\",\"交叉熵\",\"Hinge损失\",\"余弦相似度\"]','A',12,2,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(57,8,0,'以下哪个算法是集成学习方法？','[\"随机森林\",\"KNN\",\"K-Means\",\"PCA\"]','A',12,3,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(58,8,0,'神经网络的激活函数中，哪个可以将输出压缩到 (0,1)？','[\"Sigmoid\",\"ReLU\",\"Tanh\",\"Leaky ReLU\"]','A',12,4,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(59,8,0,'以下哪个是无监督学习算法？','[\"K-Means\",\"线性回归\",\"逻辑回归\",\"支持向量机\"]','A',12,5,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(60,8,1,'机器学习中，防止过拟合的技术称为 ______。',NULL,'正则化',10,6,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(61,8,1,'决策树中衡量不纯度的指标有信息增益和 ______。',NULL,'基尼指数',10,7,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(62,8,1,'CNN 中用于缩小特征图尺寸的操作是 ______。',NULL,'池化',10,8,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(63,8,1,'RNN 主要用于处理 ______ 数据。',NULL,'序列',10,9,'2026-07-14 15:16:16','2026-07-14 15:16:16'),(64,13,0,'1','[\"2\",\"3\",\"4\",\"5\"]','D',10,1,'2026-07-14 16:19:43','2026-07-14 16:19:43'),(65,13,1,'2',NULL,'3',10,2,'2026-07-14 16:19:43','2026-07-14 16:19:43'),(67,15,0,'以下哪个是面向对象的三大特性之一？','[\"封装\",\"继承\",\"多态\",\"以上都是\"]','D',10,1,'2026-07-14 16:43:54','2026-07-14 16:43:54'),(68,15,0,'HTTP 状态码 200 表示什么？','[\"请求成功\",\"重定向\",\"客户端错误\",\"服务器错误\"]','A',10,2,'2026-07-14 16:43:54','2026-07-14 16:43:54'),(69,14,0,'Spring Boot 的默认配置文件格式是？','[\"properties\",\"yml\",\"xml\",\"json\"]','A',10,1,'2026-07-14 16:50:21','2026-07-14 16:50:21');
