INSERT INTO `tb_submission` VALUES (1,1,201,'已完成登录接口联调，附 curl 命令和截图说明。',NULL,1,1,92,'接口调用完整，异常场景可以再补充。','AI 建议：增加 Token 过期场景测试。','2026-08-10 20:30:00','2026-08-11 09:00:00','2026-07-14 14:23:40','2026-07-15 10:19:41'),(2,1,202,'完成了登录、获取当前用户和权限错误测试。',NULL,1,1,88,'整体完成度较好，文档说明略少。',NULL,'2026-08-10 21:10:00','2026-08-11 09:20:00','2026-07-14 14:23:40','2026-07-15 10:19:41'),(3,3,201,'梳理了 TableName、TableId、TableLogic 的使用方式。',NULL,1,0,NULL,NULL,NULL,'2026-08-12 18:00:00',NULL,'2026-07-14 14:23:40','2026-07-14 14:23:40'),(4,11,201,'1',NULL,1,0,NULL,NULL,NULL,'2026-07-16 13:47:20',NULL,'2026-07-16 13:47:02','2026-07-16 13:47:20'),(5,10,201,'',NULL,1,0,NULL,NULL,NULL,'2026-07-16 13:50:04',NULL,'2026-07-16 13:47:58','2026-07-16 13:50:04');
