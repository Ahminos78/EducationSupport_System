# ============================================
#  教育辅助教学系统 — 本地开发环境变量示例
#  复制本文件为 .env 并按需修改
# ============================================

# ---- MySQL 数据库 ----
# 协作者请确保本地 MySQL 已运行，且包含 edu_platform 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=edu_platform
DB_USERNAME=root
DB_PASSWORD=123456

# ---- JWT 签名密钥（所有后端服务必须一致）----
EDU_JWT_SECRET=edu-platform-dev-secret-change-me

# ---- Nacos 服务注册（本地开发默认关闭）----
NACOS_ENABLED=false
SPRING_CLOUD_NACOS_DISCOVERY_SERVER_ADDR=127.0.0.1:18848

# ---- 网关 → 各微服务路由地址（本地直连）----
# EDU_USER_SERVICE_URI=http://127.0.0.1:8010
# EDU_COURSE_SERVICE_URI=http://127.0.0.1:8020
# EDU_ENROLLMENT_SERVICE_URI=http://127.0.0.1:8030
# EDU_ASSESSMENT_SERVICE_URI=http://127.0.0.1:8050
# EDU_AI_SERVICE_URI=http://127.0.0.1:8060

# ---- AI 服务 ----
# EDU_AI_DEEPSEEK_API_KEY=sk-xxxx
# EDU_AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
# EDU_AI_DEEPSEEK_MODEL=deepseek-chat
# EDU_AI_CHROMA_HOST=http://localhost
# EDU_AI_CHROMA_PORT=8000
# SILICONFLOW_API_KEY=

# ---- 前端开发服务器 ----
# VITE_API_BASE_URL=/api
